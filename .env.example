DISCORD_BOT_TOKEN=your-bot-token
DISCORD_APP_ID=your-application-id
DISCORD_APP_SECRET=your-application-secret
DISCORD_CALLBACK_URL=https://your-domain/discord/callback

# Optional HTTP proxy for JDA connections (http or https URL)
DISCORD_PROXY_URL=

# default value
DISCORD_TIMEOUT=20

# Callback server host and port (default: localhost:8131)
DISCORD_CALLBACK_HOST=localhost
DISCORD_CALLBACK_PORT=8131
